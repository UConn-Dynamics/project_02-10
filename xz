equations_text()

# ╔═╡ 70a6444d-a5b7-4a30-9436-3f17470945bd
begin
    p = DEFAULT_PARAMS
    t = 0.0
    q = consistent_configuration(t; p = p)
    C = constraint_vector(q, t; p = p)

    (
        t = t,
        q = q,
        C = C,
        max_abs_C = maximum(abs.(C)),
        labels = constraint_labels(),
    )
end

